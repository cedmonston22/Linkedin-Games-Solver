{
  "manifest_version": 3,
  "name": "LinkedIn Games Solver",
  "version": "0.1.0",
  "description": "Solver for LinkedIn games: Queens, Zip, Tango, and Patches",
  "permissions": ["activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/games/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html"
  }
}
