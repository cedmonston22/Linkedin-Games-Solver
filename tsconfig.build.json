{
  "compilerOptions": {
    "target": "ES2020",
    "module": "None",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["chrome"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/popup/popup.ts"]
}
